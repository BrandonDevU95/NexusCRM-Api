{
  "name": "nexuscrm-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "24.17.0",
    "pnpm": "11.12.0"
  },
  "packageManager": "pnpm@11.12.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:integration": "jest --config ./test/jest-integration.json",
    "test:migrations": "jest --config ./test/jest-migrations.json",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:all": "pnpm test && pnpm test:integration && pnpm test:migrations && pnpm test:e2e",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "migration:create": "typeorm-ts-node-commonjs migration:create",
    "migration:generate": "pnpm typeorm migration:generate",
    "migration:show": "pnpm typeorm migration:show",
    "migration:run": "pnpm typeorm migration:run",
    "migration:revert": "pnpm typeorm migration:revert",
    "seed:list": "ts-node -r tsconfig-paths/register src/seed/main.seed.ts list",
    "seed:run": "ts-node -r tsconfig-paths/register src/seed/main.seed.ts run",
    "infra:dev": "docker compose --env-file .env --profile devtools up -d database pgadmin",
    "infra:test": "docker compose --env-file .env.test --profile test up -d database_test",
    "infra:status": "docker compose --env-file .env --profile devtools --profile test ps",
    "infra:down": "docker compose --env-file .env --profile devtools --profile test down",
    "infra:logs:dev": "docker compose --env-file .env logs -f database",
    "infra:logs:test": "docker compose --env-file .env.test logs -f database_test"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/typeorm": "11.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "compression": "1.8.1",
    "dotenv": "17.4.1",
    "helmet": "8.3.0",
    "joi": "18.2.3",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "@nestjs/cli": "11.0.24",
    "@nestjs/schematics": "11.1.0",
    "@nestjs/testing": "11.1.28",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/jest": "29.5.14",
    "@types/node": "24.13.3",
    "@types/supertest": "7.2.0",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "jest": "29.7.0",
    "prettier": "3.9.5",
    "source-map-support": "0.5.21",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
