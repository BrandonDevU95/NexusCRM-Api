# Application
NODE_ENV=dev
APP_HOST=localhost
APP_PORT=3000
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000
COMPRESSION_ENABLED=true
COMPRESSION_THRESHOLD_BYTES=2048
COMPRESSION_LEVEL=4
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Nest runtime database: Nest runs on Windows, database runs in Docker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nexuscrm
DATABASE_USER=nexuscrm_app
DATABASE_PASSWORD=replace-with-local-dev-secret
DATABASE_SSL=false
DATABASE_LOGGING=false
DATABASE_POOL_SIZE=10
DATABASE_MIGRATIONS_RUN=false
DATABASE_SYNCHRONIZE=false

# Docker Compose development database
POSTGRES_IMAGE=postgres:17.10-bookworm@sha256:5530681ea5d3e2ed4ce396f9b5cb443efbac6baf2a8a19c0c0635e40ae7eadce
POSTGRES_CONTAINER_NAME=nexuscrm-postgres
POSTGRES_HOST_PORT=5432
POSTGRES_CONTAINER_PORT=5432
POSTGRES_DB=nexuscrm
POSTGRES_USER=nexuscrm_app
POSTGRES_PASSWORD=replace-with-local-dev-secret
POSTGRES_VOLUME_NAME=nexuscrm_postgres_data

# Docker Compose test database
TEST_POSTGRES_CONTAINER_NAME=nexuscrm-postgres-test
TEST_POSTGRES_HOST_PORT=5433
TEST_POSTGRES_DB=nexuscrm_test
TEST_POSTGRES_USER=nexuscrm_test
TEST_POSTGRES_PASSWORD=replace-with-local-test-secret
TEST_POSTGRES_VOLUME_NAME=nexuscrm_postgres_test_data
DATABASE_TEST_NAME=nexuscrm_test

# Optional pgAdmin
PGADMIN_IMAGE=dpage/pgadmin4:9.16@sha256:40fa840c5bb7c8463957f1255b01283732c2d8c9396a956d180f8e6c296753b3
PGADMIN_CONTAINER_NAME=nexuscrm-pgadmin
PGADMIN_HOST_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-local-pgadmin-secret
PGADMIN_VOLUME_NAME=nexuscrm_pgadmin_data

# Seed CLI foundation
# Demo requires SEED_RANDOM_SEED in the range 1..9007199254740991.
# SEED_BATCH_SIZE accepts 1..1000.
SEED_RANDOM_SEED=20260713
SEED_BATCH_SIZE=100
SEED_ALLOW_DEMO_DATA=false
